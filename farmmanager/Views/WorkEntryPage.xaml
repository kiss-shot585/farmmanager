<Page
    x:Class="farmmanager.Views.WorkEntryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="32,24,32,0">
            <StackPanel>
                <TextBlock Text="Work Entry" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Record daily work objectives and financial data"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Padding="32,16,32,24" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" VerticalAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Padding="0,0,12,0">

                        <Grid>
                            <TextBlock
                              x:Name="FormTitle"
                              Text="New Work Entry"
                              FontSize="15"
                              FontWeight="SemiBold"/>
                            <Button x:Name="CancelEditBtn"
                                    Content="Cancel"
                                    HorizontalAlignment="Right"
                                    Visibility="Collapsed"
                                    Click="CancelEdit_Click"/>
                        </Grid>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Date" Style="{StaticResource SectionHeaderStyle}"/>
                            <CalendarDatePicker
                                     x:Name="EntryDatePicker"
                                     HorizontalAlignment="Stretch"
                                     PlaceholderText="Select date"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Worker *" Style="{StaticResource SectionHeaderStyle}"/>
                            <AutoSuggestBox
                                    x:Name="WorkerCombo"
                                    HorizontalAlignment="Stretch"
                                    PlaceholderText="Type Worker Name..."
                                    DisplayMemberPath="Name"
                                    TextChanged="WorkerSuggestBox_TextChanged"
                                    SuggestionChosen="WorkerSuggestBox_SuggestionChosen"
                                    UpdateTextOnSelect="True"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Plantation Parcel *" Style="{StaticResource SectionHeaderStyle}"/>
                            <AutoSuggestBox
                                    x:Name="ParcelCombo"
                                    HorizontalAlignment="Stretch"
                                    PlaceholderText="Type Parcel Code"
                                    DisplayMemberPath="Name"
                                    TextChanged="ParcelSuggestBox_TextChanged"
                                    SuggestionChosen="ParcelSuggestBox_SuggestionChosen"
                                    UpdateTextOnSelect="True"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Activity *" Style="{StaticResource SectionHeaderStyle}"/>
                            <AutoSuggestBox
                                    x:Name="ActivityCombo"
                                    HorizontalAlignment="Stretch"
                                    PlaceholderText="Type Activity..."
                                    DisplayMemberPath="Name"
                                    TextChanged="ActivitySuggestBox_TextChanged"
                                    SuggestionChosen="ActivitySuggestBox_SuggestionChosen"
                                    UpdateTextOnSelect="True"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Objective of the Day" Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBox
                                   x:Name="ObjectiveTxt"
                                   PlaceholderText="Describe the day's objective..."
                                   TextWrapping="Wrap"
                                   Height="72"
                                   AcceptsReturn="True"/>
                        </StackPanel>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Objective Planned" Style="{StaticResource SectionHeaderStyle}"/>
                                <NumberBox
                                       x:Name="PlannedBox"
                                       Minimum="0"
                                       SpinButtonPlacementMode="Compact"
                                       PlaceholderText="0.00"
                                       ValueChanged="Amount_ValueChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Objective Attained" Style="{StaticResource SectionHeaderStyle}"/>
                                <NumberBox
                                         x:Name="AttainedBox"
                                         Minimum="0"
                                         SpinButtonPlacementMode="Compact"
                                         PlaceholderText="0.00"
                                         ValueChanged="Amount_ValueChanged"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Daily Wage Override (FCFA)" Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBlock
                                  Text="Leave at 0 to auto-calculate from activity rate"
                                  FontSize="11"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <NumberBox
                                   x:Name="DailyWageBox"
                                   Minimum="0"
                                   SpinButtonPlacementMode="Compact"
                                   PlaceholderText="0"
                                   ValueChanged="Amount_ValueChanged"/>
                        </StackPanel>

                        <Border
                              Background="{ThemeResource AccentFillColorTertiaryBrush}"
                              CornerRadius="6"
                              Padding="12,10">
                            <Grid>
                                <TextBlock
                                     Text="Amount Earned:"
                                     FontWeight="SemiBold"
                                     VerticalAlignment="Center"/>
                                <TextBlock
                                     x:Name="ComputedAmountText"
                                     Text="0 FCFA"
                                     HorizontalAlignment="Right"
                                     FontWeight="Bold"
                                     FontSize="18"
                                     Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                     VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Grid ColumnSpacing="8" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button
                               Grid.Column="0"
                               x:Name="SaveBtn"
                               Content="Save Entry"
                               HorizontalAlignment="Stretch"
                               Style="{StaticResource CustomAccentButtonStyle}"
                               Click="SaveEntry_Click"/>
                            <Button
                               Grid.Column="1"
                               x:Name="DeleteBtn"
                               Content="Delete"
                               Foreground="White"
                               Background="Crimson"
                               Visibility="Collapsed"
                               Click="DeleteEntry_Click"/>
                        </Grid>

                        <TextBlock
                             x:Name="StatusText"
                             TextWrapping="Wrap"
                             FontSize="12"
                             Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBlock Text="Work Log" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                            <CalendarDatePicker x:Name="FilterFromPicker" PlaceholderText="From" Width="160"/>
                            <CalendarDatePicker x:Name="FilterToPicker" PlaceholderText="To" Width="160"/>
                            <Button Content="Filter" Click="Filter_Click"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Padding="12,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Date" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="Worker" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="2" Text="Group" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="3" Text="Parcel" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="4" Text="Activity" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="5" Text="Objective" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="6" Text="Amount (FCFA)" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Right"/>
                    </Grid>

                    <ListView
                        Grid.Row="2"
                        x:Name="EntriesListView"
                        SelectionChanged="EntriesListView_SelectionChanged"
                        SelectionMode="Single">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="12,6"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                        Text="{Binding Date, Converter={StaticResource DateTimeToStringConverter}}"
                                        FontSize="12" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Worker.Name}" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                        Text="{Binding Worker.Group}"
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3"
                                        Text="{Binding Parcel.Name}"
                                        FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4"
                                        Text="{Binding Activity.Name}"
                                        FontSize="12"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                        VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="5"
                                        Text="{Binding ObjectiveOfDay}"
                                        FontSize="12"
                                        TextTrimming="CharacterEllipsis"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="6"
                                        Text="{Binding AmountEarned, Converter={StaticResource DecimalToCurrencyConverter}}"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        HorizontalAlignment="Right"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                        VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>