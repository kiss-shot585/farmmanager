<Page
    x:Class="farmmanager.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Spacing="20" Padding="32,24">

            <StackPanel>
                <TextBlock Text="Dashboard" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock
                    x:Name="SubtitleText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    FontSize="13"/>
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource KpiCardStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="💰 Total This Month" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock
                            x:Name="TotalMonthText"
                            Text="Loading..."
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock
                            x:Name="TotalMonthLabel"
                            Text="FCFA"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource KpiCardStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="👷 Active Workers" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock
                            x:Name="WorkerCountText"
                            Text="—"
                            FontSize="26"
                            FontWeight="Bold"/>
                        <TextBlock
                            x:Name="WorkerGroupsText"
                            Text="workers"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource KpiCardStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="📋 Entries Today" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock
                            x:Name="TodayEntriesText"
                            Text="—"
                            FontSize="26"
                            FontWeight="Bold"/>
                        <TextBlock
                            Text="work log entries"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource KpiCardStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="🌱 Active Parcels" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock
                            x:Name="ParcelCountText"
                            Text="—"
                            FontSize="26"
                            FontWeight="Bold"/>
                        <TextBlock
                            Text="plantation parcels"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="12">
                        <Grid>
                            <TextBlock Text="Recent Work Entries" Style="{StaticResource SectionHeaderStyle}"
                                       VerticalAlignment="Center"/>
                            <Button Content="New Entry" HorizontalAlignment="Right"
                                    Style="{StaticResource CustomAccentButtonStyle}"
                                    Click="QuickAddEntry_Click"/>
                        </Grid>
                        <ListView
                            x:Name="RecentEntriesList"
                            MaxHeight="320"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,6" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                            Text="{Binding Date, Converter={StaticResource DateTimeToStringConverter}}"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Worker.Name}" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding Worker.Group}" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding Parcel.Name}" FontSize="13"/>
                                            <TextBlock Text="{Binding Activity.Name}" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="3"
                                            Text="{Binding AmountEarned, Converter={StaticResource DecimalToCurrencyConverter}}"
                                            FontWeight="SemiBold"
                                            FontSize="13"
                                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                            VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Top Workers This Month" Style="{StaticResource SectionHeaderStyle}"/>
                        <ListView
                            x:Name="TopWorkersList"
                            MaxHeight="320"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,4" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding WorkerName}" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding Group}" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                            Text="{Binding TotalAmountEarned, Converter={StaticResource DecimalToCurrencyConverter}}"
                                            FontSize="12" FontWeight="SemiBold"
                                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                            VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>